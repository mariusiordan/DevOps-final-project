# ============================================================
# PostgreSQL docker-compose
# Managed by Ansible - do not edit by hand
# ============================================================

services:
  postgres:
    # Official PostgreSQL image - alpine variant (smaller, ~80MB vs ~240MB)
    image: postgres:16-alpine
    container_name: postgres
    restart: unless-stopped   # restart automatically, unless manually stopped

    environment:
      # Credentials - actual values come from Ansible Vault (vault.yml)
      POSTGRES_USER:     {{ db_user }}
      POSTGRES_PASSWORD: {{ db_password }}
      POSTGRES_DB:       {{ db_name }}

    volumes:
      # Mount host directory to /var/lib/postgresql/data
      # All database files are stored on the host - survives container restart
      - /opt/postgres/data:/var/lib/postgresql/data

    ports:
      # Bind to the VM's private IP ONLY - not to 0.0.0.0
      # This prevents exposing postgres on other interfaces (docker0, etc)
      # db_ip comes from group_vars/all/main.yml (auto-generated by Terraform)
      - "{{ db_ip }}:5432:5432"

    healthcheck:
      # Docker built-in health check
      # Runs pg_isready every 10s - marks container unhealthy if DB is down
      test: ["CMD-SHELL", "pg_isready -U {{ db_user }} -d {{ db_name }}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s   # don't fail during initial 30s startup