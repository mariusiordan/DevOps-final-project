# ============================================================
# app.conf
# Managed by Ansible - do not edit by hand
# 
# Main nginx site config
# Routes:
#   /api/*  → backend Express container (port 4000)
#   /*      → frontend Next.js container (port 3000)
# ============================================================

server {
    listen 80;
    server_name _;   # accept any hostname

    # Increase max body size for file uploads (default is 1MB)
    client_max_body_size 10M;

    # API requests → backend Express container
    # IMPORTANT: /api/ must be BEFORE location / to take priority
    location /api/ {
        proxy_pass http://app_backend_api;

        # Standard reverse proxy headers
        # These tell the backend about the original request
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Cookie            $http_cookie;

        # Timeouts - wait up to 60s for backend response
        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;
    }

    # All other requests → frontend Next.js container
    location / {
        proxy_pass http://app_frontend;

        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Next.js needs WebSocket support for hot reload in dev mode
        # These headers enable WebSocket upgrade
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;
    }
}