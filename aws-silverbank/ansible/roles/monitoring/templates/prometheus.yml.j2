# prometheus.yml
# Managed by Ansible - do not edit by hand
# Scrape targets use AWS private IPs from group_vars (auto-updated by Terraform)

global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  # Prometheus monitors itself
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  # node-exporter on every VM - system metrics (CPU, RAM, disk)
  - job_name: 'node-exporter'
    static_configs:
      - targets:
          - '{{ monitoring_ip }}:9100'   # monitoring-staging
          - '{{ edge_private_ip }}:9100'   # edge-nginx (private IP)         # edge-nginx
          - '{{ blue_app_ip }}:9100'     # prod-blue
          - '{{ green_app_ip }}:9100'    # prod-green
          - '{{ db_app_ip }}:9100'       # db-postgresql

  # SilverBank backend - application metrics / health
  - job_name: 'app-backend'
    metrics_path: /api/health
    static_configs:
      - targets:
          - '{{ blue_app_ip }}:{{ app_port_backend }}'
          - '{{ green_app_ip }}:{{ app_port_backend }}'