# app/templates/.env.j2
# Environment variables for the SilverBank app
# Managed by Ansible - do not edit by hand

NODE_ENV=production

# Database connection string
DATABASE_URL=postgresql://{{ db_user }}:{{ db_password }}@{{ db_host }}:{{ db_port }}/{{ db_name }}

# JWT secret for signing auth tokens
JWT_SECRET={{ vault_jwt_secret }}

# Frontend URL for CORS (backend allows requests from this origin)
FRONTEND_URL=http://{{ edge_ip }}

# Health endpoint metadata - shows which version/env is running
DEPLOY_ENV=production
IMAGE_TAG={{ app_tag }}
APP_VERSION={{ app_tag }}