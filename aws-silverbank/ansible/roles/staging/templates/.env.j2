# roles/staging/templates/.env.j2
# Managed by Ansible - do not edit by hand
NODE_ENV=production

# Points to the LOCAL postgres container (service name, internal Docker network)
# NOT the production database
DATABASE_URL=postgresql://{{ db_user }}:{{ db_password }}@postgres:5432/{{ staging_db_name }}

JWT_SECRET={{ vault_jwt_secret }}
FRONTEND_URL=http://localhost:{{ staging_port_frontend }}

DEPLOY_ENV=staging
IMAGE_TAG={{ staging_tag }}
APP_VERSION={{ staging_tag }}
