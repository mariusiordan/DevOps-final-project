# =============================
# Terraform
# =============================

# Local Terraform directory and lock file
.terraform/
.terraform.lock.hcl

# State files - may contain secrets in plain text
terraform.tfstate
terraform.tfstate.*

# Crash logs
crash.log

# Local variable files with secrets
terraform.tfvars
*.auto.tfvars

# Terraform override files
override.tf
override.tf.json
*_override.tf

# =============================
# Ansible
# =============================

# Auto-generated by Terraform - contains IP addresses
ansible/inventory.ini

# Ansible retry files from failed playbooks
ansible/*.retry

# Ansible Vault encrypted files
ansible/group_vars/*/vault.yml
vault-password.txt
~/.vault-password    # nu e în proiect deci nu contează
ansible/group_vars/vault.yml   # ← NU adaugi asta - vault.yml MERGE în git criptat
# =============================
# SSH / Secrets
# =============================

# SSH private keys
*.pem
*.key
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# Secret and environment files
*.secret
.env
.env.*
secrets.yml

# Local SSH known_hosts overrides
.known_hosts

# =============================
# macOS
# =============================

.DS_Store
.AppleDouble
.LSOverrideFile

# =============================
# Editor / IDE
# =============================

.vscode/
.idea/
*.swp
*.swo