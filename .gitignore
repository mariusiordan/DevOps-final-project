# =============================
# Terraform
# =============================

# Local Terraform directory and lock file
.terraform/
.terraform.lock.hcl

# Exception — track lock file for new AWS project
!aws-silverbank-ec2/terraform/.terraform.lock.hcl

# State files - may contain secrets in plain text
terraform.tfstate
terraform.tfstate.*

# Crash logs
crash.log

# Local variable files with secrets
terraform.tfvars
*.auto.tfvars

# Terraform override files
override.tf
override.tf.json
*_override.tf

# =============================
# Ansible
# =============================

# Auto-generated by Terraform - contains IP addresses
ansible/inventory.ini

# Auto-generated by Terraform - contains IP addresses
aws-silverbank/ansible/inventory-aws.ini
aws-silverbank/ansible/group_vars/all/main.yml
aws-silverbank/ansible/group_vars/prod.yml

# Ansible retry files from failed playbooks
ansible/*.retry

# Ansible Vault encrypted files
ansible/group_vars/*/vault.yml
vault-password.txt
~/.vault-password    # nu e în proiect deci nu contează
ansible/group_vars/vault.yml   # ← NU adaugi asta - vault.yml MERGE în git criptat
# =============================
# SSH / Secrets
# =============================

# SSH private keys
*.pem
*.key
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# Secret and environment files
*.secret
.env
.env.*
secrets.yml
!.env.j2

# Local SSH known_hosts overrides
.known_hosts

# =============================
# macOS
# =============================

.DS_Store
.AppleDouble
.LSOverrideFile

# =============================
# Editor / IDE
# =============================

.vscode/
.idea/
*.swp
*.swo

!silverbank-infrastructure.svg

# Terraform sensitive values
aws-silverbank-ec2/terraform/terraform-aws.tfvars