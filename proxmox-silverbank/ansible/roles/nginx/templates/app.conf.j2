# app.conf.j2
# Main nginx site configuration
# Routes traffic to frontend (port 3000) and backend API (port 4000)
# Both upstreams point to the same Blue or Green VM

server {
    listen 80;
    server_name _;

    # API requests → backend Express container (port 4000)
    # Must be before location / to take priority
    location /api/ {
        proxy_pass http://app_backend_api\;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Cookie            $http_cookie;
        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;
    }

    # All other requests → frontend Next.js container (port 3000)
    location / {
        proxy_pass http://app_frontend\;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;
    }
}
