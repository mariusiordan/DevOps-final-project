# upstream.conf.j2
# Blue/Green upstream configuration
# switch-backend.sh updates this file to switch traffic between BLUE and GREEN
# Both frontend (3000) and backend API (4000) switch together

upstream app_frontend {
    server {{ blue_app_ip }}:3000;      # BLUE frontend - active
    # server {{ green_app_ip }}:3000;   # GREEN frontend - inactive
}

upstream app_backend_api {
    server {{ blue_app_ip }}:4000;      # BLUE backend API - active
    # server {{ green_app_ip }}:4000;   # GREEN backend API - inactive
}
