global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node-exporter'
    static_configs:
      - targets:
          - '192.168.7.70:9100'    # monitoring-staging
          - '192.168.7.50:9100'    # edge-nginx
          - '192.168.7.101:9100'   # prod-blue
          - '192.168.7.102:9100'   # prod-green
          - '192.168.7.60:9100'    # db-postgresql

  - job_name: 'silverbank-backend'
    static_configs:
      - targets:
          - '{{ blue_app_ip }}:4000'
          - '{{ green_app_ip }}:4000'
