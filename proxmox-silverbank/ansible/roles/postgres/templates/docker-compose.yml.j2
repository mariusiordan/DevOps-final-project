# postgres/templates/docker-compose.yml.j2
# Docker Compose file for PostgreSQL
# Variables like {{ postgres_user }} come from group_vars/db.yml

services:
  postgres:
    image: postgres:16-alpine  # alpine = smaller image size
    container_name: postgres
    restart: unless-stopped    # restart automatically unless we manually stop it

    environment:
      POSTGRES_USER:     {{ postgres_user }}
      POSTGRES_PASSWORD: {{ postgres_password }}
      POSTGRES_DB:       {{ postgres_db }}

    volumes:
      # Mount the data directory so database files survive container restarts
      - {{ postgres_data_dir }}:/var/lib/postgresql/data

    ports:
      # Bind only to the internal APP network IP - not accessible from outside
      - "{{ hostvars[inventory_hostname]['ansible_eth1']['ipv4']['address'] }}:{{ postgres_port }}:5432"

    healthcheck:
      # Check if postgres is ready to accept connections
      test: ["CMD-SHELL", "pg_isready -U {{ postgres_user }} -d {{ postgres_db }}"]
      interval: 10s   # check every 10 seconds
      timeout: 5s     # wait max 5 seconds for response
      retries: 5      # mark as unhealthy after 5 failures