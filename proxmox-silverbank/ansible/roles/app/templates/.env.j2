# app/templates/.env.j2
# Environment variables for the Node.js app
# This file is copied to /opt/app/.env on the production VMs
# Variables come from group_vars/prod.yml

NODE_ENV=production
PORT={{ app_port_backend }}

# Database connection string - connects via internal APP network (vmbr1)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://{{ db_user }}:{{ db_password }}@{{ db_host }}:{{ db_port }}/{{ db_name }}
JWT_SECRET={{ vault_jwt_secret }}
