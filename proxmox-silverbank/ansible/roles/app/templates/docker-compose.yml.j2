services:
  frontend:
    image: {{ frontend_image }}:{{ app_tag }}
    container_name: silverbank-frontend
    restart: unless-stopped
    env_file: .env
    ports:
      - "3000:3000"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

  backend:
    image: {{ backend_image }}:{{ app_tag }}
    container_name: silverbank-backend
    restart: unless-stopped
    env_file: .env
    ports:
      - "4000:4000"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:4000/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s